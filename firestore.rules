rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn();
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    match /content/singleton {
      // Allow read for everyone to see the website content.
      allow get: if true;
      allow list: if false; 
      allow write: if isAdmin();
    }

    match /courses/{courseId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(courseId);
    }

    match /registrations/{registrationId} {
      // Allow any user (even unauthenticated) to submit a registration
      allow create: if true;
      // Only admin can read and update
      allow read, update, delete: if isAdmin();
    }
  }
}
